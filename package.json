{
  "name": "dataviz-toolkit",
  "version": "0.1.0",
  "description": "A JavaScript library for creating interactive data visualizations",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c -w",
    "test": "jest",
    "lint": "eslint src/**/*.js",
    "format": "prettier --write src/**/*.js"
  },
  "keywords": [
    "data visualization",
    "charts",
    "graphs",
    "javascript",
    "library"
  ],
  "author": "DataViz Team",
  "license": "MIT",
  "devDependencies": {
    "@rollup/plugin-commonjs": "^24.0.0",
    "@rollup/plugin-node-resolve": "^15.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.0.0",
    "prettier": "^2.0.0",
    "rollup": "^3.0.0",
    "rollup-plugin-terser": "^7.0.0"
  },
  "dependencies": {
    "d3": "^7.0.0"
  }
}